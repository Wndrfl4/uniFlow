# ============================================================
# UniFlow Blog — шаблон переменных окружения
# Скопируйте этот файл в .env и заполните реальными значениями
# НИКОГДА не коммитьте .env файл в git!
# ============================================================

# --- База данных ---
DB_URL=jdbc:postgresql://postgres:5432/uniflow
DB_USERNAME=uniflow
DB_PASSWORD=uniflow

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- JWT ---
# Генерация: openssl rand -hex 32
JWT_SECRET=ВАШ_СЕКРЕТНЫЙ_КЛЮЧ_НЕ_МЕНЕЕ_32_СИМВОЛОВ
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- AI Провайдер ---
# Выберите один: mock | gemini | groq | openrouter
AI_PROVIDER=mock

# Google Gemini (бесплатно: 15 запр/мин, 1М токенов/день)
# Получить ключ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq (бесплатно: самый быстрый inference)
# Получить ключ: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (бесплатные модели без лимитов)
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# --- Сервер ---
SERVER_PORT=8080
SITE_URL=http://localhost:8080

# --- Безопасность ---
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=15
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Загрузки ---
UPLOAD_DIR=./uploads
